<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Fraunces:ital,opsz,wght@0,9..144,300;1,9..144,300&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300;1,8..60,400&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,700;1,400&family=Playfair+Display:wght@400;700&family=Exo+2:wght@800&display=swap" rel="stylesheet">

<!-- TemplateBeginEditable name="doctitle" -->
<title>m kirk</title>
<meta name="description" content="m kirk — author of fiction and nonfiction.">
<!-- TemplateEndEditable -->

<style>

/* ── RESET ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}

/* ── TOKENS ── */
:root{
  --denim:      #3D6E8A;
  --denim-d:    #2E5570;
  --cream:      #F2EDE3;    /* card surface */
  --cream-d:    #E6DFD1;    /* cover column tint */
  --ink:        #14100E;    /* primary text on cream */
  --ink-mid:    rgba(20,16,14,.5);
  --ink-dim:    rgba(20,16,14,.35);
  --gold:       #C9A85C;
  --balance-navy: #0D1B2A;
  --rust:       #B85638;
  --rust-h:     #D4704A;
  --accent:     #5BA67C;
  --accent-d:   #3D8A62;
  --warm:       #EDE9E2;
  --parch:      #EAE0D0;
  --nav-bg:     #14181C;
}

body{
  background:var(--denim);
  color:var(--ink);
  font-family:'Source Serif 4',serif;
  font-size:17px;
  line-height:1.75;
  -webkit-font-smoothing:antialiased;
}

/* ── SKIP LINK (accessibility) ── */
.skip-link{
  position:absolute;left:-9999px;
  background:var(--gold);color:#0C0B09;
  padding:8px 16px;font-size:14px;
  text-decoration:none;z-index:999;
}
.skip-link:focus{left:12px;top:12px;}

/* ── NAV ── */
nav{
  position:sticky;top:0;z-index:100;
  background:var(--nav-bg);
  border-bottom:1px solid rgba(220,220,230,.22);
  padding:12px 40px;
}
.nav-inner{
  max-width:1100px;margin:0 auto;
  display:flex;align-items:center;justify-content:space-between;
}
.nav-mark{
  font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:400;
  font-size:48px;letter-spacing:-.01em;
  color:var(--gold);text-decoration:none;line-height:1;
}
.nav-links a{
  font-family:'Source Serif 4',serif;font-size:18px;
  color:var(--rust);text-decoration:none;
  padding:0 20px;transition:color .2s;
}
.nav-links a:hover{color:var(--rust-h);}
.nav-links a.active{color:var(--warm);}

/* ── FOOTER ── */
footer{background:#0E1216;border-top:1px solid rgba(91,166,124,.1);padding:40px;}
.foot-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;}
.foot-left{display:flex;flex-direction:column;gap:8px;}
.foot-mark{
  font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:400;
  font-size:48px;line-height:1;
  color:var(--gold);letter-spacing:.04em;word-spacing:-.1em;text-decoration:none;
}
.foot-social{display:flex;align-items:center;gap:8px;text-decoration:none;}
.foot-social span{font-family:'Source Serif 4',serif;font-size:16px;color:#fff;}
.foot-copyright{font-family:'Source Serif 4',serif;font-size:17px;color:var(--rust);letter-spacing:.04em;text-align:right;}

/* ── RESPONSIVE ── */
@media(max-width:960px){
  nav{padding:0 24px;}
}
@media(max-width:640px){
  footer{padding:32px 24px;}
  .foot-inner{flex-direction:column;align-items:flex-start;gap:20px;}
  .foot-copyright{text-align:left;}
}

/* ── ENTRY ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}

</style>

<!-- TemplateBeginEditable name="page-styles" -->
<!-- Page-specific styles go here -->
<!-- TemplateEndEditable -->

</head>
<body>

<a class="skip-link" href="#main-content">Skip to content</a>

<nav aria-label="Main navigation">
  <div class="nav-inner">
    <a href="index.html" class="nav-mark">m kirk</a>
    <div class="nav-links">
      <!-- TemplateBeginEditable name="nav-links" -->
      <a href="index.html">About</a>
      <a href="books.html">Books</a>
      <a href="newsletter.html">Newsletter</a>
      <!-- TemplateEndEditable -->
    </div>
  </div>
</nav>

<main id="main-content">
<!-- TemplateBeginEditable name="main-content" -->

<!-- YOUR PAGE CONTENT GOES HERE -->

<!-- TemplateEndEditable -->
</main>

<footer>
  <div class="foot-inner">
    <div class="foot-left">
      <a href="index.html" class="foot-mark">m kirk</a>
      <a href="https://instagram.com/mkirkwrites" target="_blank" rel="noopener" class="foot-social" aria-label="Instagram: @mkirkwrites">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="#fff" stroke="none"/>
        </svg>
        <span>@mkirkwrites</span>
      </a>
    </div>
    <div class="foot-copyright">© m kirk · All rights reserved</div>
  </div>
</footer>

</body>
</html>
